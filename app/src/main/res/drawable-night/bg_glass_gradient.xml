<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#0B0D12"
                android:endColor="#0F1320" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="90%p"
                android:centerX="0.1"
                android:centerY="0.1"
                android:startColor="#2A1F3A5C"
                android:endColor="#00000000" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="100%p"
                android:centerX="0.95"
                android:centerY="0.95"
                android:startColor="#2A2C345A"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
