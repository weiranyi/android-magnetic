<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_glass_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp">

        <!-- Logo 区域 - 纯净太极图 -->
        <ImageView
            android:id="@+id/splashLogo"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_marginBottom="28dp"
            android:src="@drawable/ic_splash_logo_vector"
            android:scaleType="fitCenter" />

        <!-- 应用名称 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name_chinese"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/splash_text_primary"
            android:gravity="center"
            android:letterSpacing="0.03" />

        <!-- 副标题（英文） -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/app_name_subtitle"
            android:textSize="14sp"
            android:textColor="@color/splash_text_secondary"
            android:gravity="center"
            android:letterSpacing="0.05" />

        <!-- 启动进度条区域 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="52dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <!-- 进度条 -->
            <ProgressBar
                android:id="@+id/splashProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="200dp"
                android:layout_height="5dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/splash_progress_horizontal"
                android:indeterminate="false" />

            <!-- 进度百分比文字 -->
            <TextView
                android:id="@+id/splashProgressText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="0%"
                android:textSize="12sp"
                android:textColor="@color/splash_text_tertiary"
                android:fontFamily="monospace" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
